# Frontend app URL under test
E2E_BASE_URL=http://localhost:5173

# Test database URL used by E2E reset hooks (required)
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/arrowhead_test

# Optional: allow reset even if DATABASE_URL_TEST does not contain the word "test"
E2E_ALLOW_NON_TEST_DB_RESET=false

# Let E2E manage its own backend process (recommended)
E2E_USE_EXISTING_BACKEND=false

# Backend port used by managed E2E backend
E2E_BACKEND_PORT=5001

# Login credentials for seeded Staff account
SEED_STAFF_USERNAME=staff
SEED_STAFF_PASSWORD=your-seeded-staff-password
SEED_OWNER_USERNAME=owner
SEED_OWNER_PASSWORD=your-seeded-owner-password

# Headless toggle for CI or local runs (true/false)
E2E_HEADLESS=false

E2E_UI_TIMEOUT_MS=60000